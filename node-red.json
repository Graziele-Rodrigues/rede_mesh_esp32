        "type": "function",
        "z": "fe162edfc74f05cc",
        "name": "data_sensor",
        "func": "const payload = msg.payload;\n\n// Validação básica para garantir que os dados existem e são do tipo correto\nif (!payload || typeof payload !== 'object' || !payload.mac || isNaN(payload.temp) || isNaN(payload.hum) || isNaN(payload.latency_ms)) {\n    node.warn(\"Dados de sensor inválidos ou incompletos. Pulando inserção no banco de dados.\");\n    return null; // Não envia a mensagem adiante se os dados forem inválidos\n}\n\nconst macAddress = payload.mac;\nconst temperature = parseFloat(payload.temp).toFixed(2); // Formata para 2 casas decimais\nconst humidity = parseFloat(payload.hum).toFixed(2);     // Formata para 2 casas decimais\nconst latencyMs = parseInt(payload.latency_ms, 10);      // Garante que é um inteiro\n\n// Monta a query SQL\n// Usamos aspas simples para os valores STRING (mac_address) e sem aspas para números\nmsg.topic = `INSERT INTO mesh_sensor_data (mac_address, temperature, humidity, latency_ms) VALUES ('${macAddress}', ${temperature}, ${humidity}, ${latencyMs});`;\n\nreturn msg;",
