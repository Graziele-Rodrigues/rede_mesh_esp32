    {
        "id": "d912d806d898c021",
        "type": "ui_template",
        "z": "fe162edfc74f05cc",
        "group": "fd8240562a77573a",
        "name": "Gráficos",
        "order": 14,
        "width": 13,
        "height": 12,
        "format": "<script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n\n<style>\n    .chart-container {\n        display: flex;\n        flex-wrap: wrap;\n        gap: 20px;\n        justify-content: center;\n        align-items: flex-start;\n        margin-top: 20px;\n    }\n\n    .chart-box {\n        flex: 1 1 300px;\n        min-width: 300px;\n        max-width: 500px;\n    }\n\n    canvas {\n        width: 100% !important;\n        height: 300px !important;\n    }\n</style>\n\n<div class=\"chart-container\">\n    <div class=\"chart-box\">\n        <h4>Temperatura por MAC</h4>\n        <canvas id=\"chartTemp\"></canvas>\n    </div>\n    <div class=\"chart-box\">\n        <h4>Umidade por MAC</h4>\n        <canvas id=\"chartHum\"></canvas>\n    </div>\n    <div class=\"chart-box\">\n        <h4>Latência por MAC</h4>\n        <canvas id=\"chartLat\"></canvas>\n    </div>\n</div>\n\n<script>\n    const macColors = {};\n\n    function getColorForMac(mac) {\n        if (macColors[mac]) return macColors[mac];\n\n        function getRandomColor() {\n            const r = Math.floor(Math.random() * 200);\n            const g = Math.floor(Math.random() * 200);\n            const b = Math.floor(Math.random() * 200);\n            return `rgba(${r}, ${g}, ${b}, 0.6)`;\n        }\n\n        macColors[mac] = getRandomColor();\n        return macColors[mac];\n    }\n\n    // Variáveis para armazenar as instâncias dos gráficos globalmente no escopo do template\n    let chartTempInstance;\n    let chartHumInstance;\n    let chartLatInstance;\n\n    // Função para criar a configuração básica de cada gráfico\n    function createChartConfig(label) {\n        return {\n            type: 'line',\n            data: {\n                labels: [],\n                datasets: []\n            },\n            options: {\n                responsive: true,\n                animation: false, // Pode ser 'false' para gráficos em tempo real\n                plugins: {\n                    legend: { display: true },\n                    title: { display: false }\n                },\n                scales: {\n                    y: { beginAtZero: true },\n                    x: { ticks: { autoSkip: true, maxTicksLimit: 10 } }\n                }\n            }\n        };\n    }\n\n    // Função para adicionar um novo dataset (linha) ao gráfico\n    function addDataset(chart, label, color) {\n        // Evita adicionar o mesmo dataset múltiplas vezes\n        if (!chart.data.datasets.some(d => d.label === label)) {\n            chart.data.datasets.push({\n                label: label,\n                data: [],\n                borderColor: color,\n                backgroundColor: color,\n                fill: false,\n                tension: 0.1\n            });\n            chart.update(); // Atualiza o gráfico após adicionar o dataset\n            console.log(`[Chart] Dataset '${label}' adicionado.`);\n        }\n    }\n\n    // Função para atualizar os dados de um dataset existente\n    function updateChartData(chart, label, labels, data) {\n        const dataset = chart.data.datasets.find(d => d.label === label);\n        if (dataset) {\n            dataset.data = data;\n            // Atualiza os labels do eixo X para todos os datasets no gráfico\n            chart.data.labels = labels;\n            chart.update(); // Atualiza o gráfico\n            // console.log(`[Chart] Dados para '${label}' atualizados.`);\n        }\n    }\n\n    // O código principal dentro do escopo do Node-RED UI-Template\n    (function(scope) {\n        const chartData = {}; // Histórico por MAC\n\n        // Função de inicialização dos gráficos, a ser chamada quando o DOM estiver pronto\n        function initCharts() {\n            const chartTempCtx = document.getElementById('chartTemp');\n            const chartHumCtx = document.getElementById('chartHum');\n            const chartLatCtx = document.getElementById('chartLat');\n\n            if (chartTempCtx && chartHumCtx && chartLatCtx) {\n                console.log(\"[Chart Init] Canvas elements found. Initializing charts.\");\n                chartTempInstance = new Chart(chartTempCtx.getContext('2d'), createChartConfig(\"Temperatura (°C)\"));\n                chartHumInstance = new Chart(chartHumCtx.getContext('2d'), createChartConfig(\"Umidade (%)\"));\n                chartLatInstance = new Chart(chartLatCtx.getContext('2d'), createChartConfig(\"Latência (ms)\"));\n            } else {\n                console.error(\"[Chart Init] Canvas elements NOT found. Charts will not be initialized.\");\n                // Tenta novamente após um pequeno atraso se não encontrar\n                setTimeout(initCharts, 100);\n            }\n        }\n\n        // --- Evento de Pronto do Node-RED UI-Template ---\n        // Garante que o DOM esteja carregado antes de tentar criar os gráficos\n        scope.$on('ready', function() {\n            console.log(\"[Node-RED UI] 'ready' event fired. Attempting to initialize charts.\");\n            initCharts();\n        });\n\n        // --- Listener para mensagens do Node-RED ---\n        scope.$watch('msg.payload', function(data) {\n            console.log(\"[Msg Watch] Message received:\", data);\n\n            // Verifica se a mensagem é válida e contém as propriedades necessárias\n            if (!data || typeof data !== 'object' || !data.mac || isNaN(data.temp) || isNaN(data.hum) || isNaN(data.latency_ms)) {\n                console.warn(\"[Msg Watch] Invalid or incomplete data received. Skipping update.\", data);\n                return;\n            }\n\n            // Garante que as instâncias dos gráficos existem antes de tentar atualizá-los\n            if (!chartTempInstance || !chartHumInstance || !chartLatInstance) {\n                console.warn(\"[Msg Watch] Charts not yet initialized. Data will be processed once charts are ready.\");\n                // Se os gráficos não estão prontos, podemos armazenar os dados e tentar processar depois\n                // (Para este exemplo, vamos apenas retornar, pois o initCharts já tem um retry)\n                return;\n            }\n\n            const mac = String(data.mac); // Garante que MAC seja string\n            const temp = parseFloat(data.temp);\n            const hum = parseFloat(data.hum);\n            const lat = parseFloat(data.latency_ms);\n            const timestamp = new Date().toLocaleTimeString();\n\n            if (!chartData[mac]) {\n                chartData[mac] = {\n                    labels: [],\n                    temp: [],\n                    hum: [],\n                    lat: []\n                };\n                console.log(`[Msg Watch] New MAC detected: ${mac}. Adding datasets.`);\n                const color = getColorForMac(mac);\n                addDataset(chartTempInstance, mac, color);\n                addDataset(chartHumInstance, mac, color);\n                addDataset(chartLatInstance, mac, color);\n            }\n\n            const maxPoints = 20; // Limite de pontos no gráfico\n            const macData = chartData[mac];\n\n            // Garante que os arrays de dados e labels não cresçam indefinidamente\n            if (macData.labels.length >= maxPoints) {\n                macData.labels.shift();\n                macData.temp.shift();\n                macData.hum.shift();\n                macData.lat.shift();\n            }\n\n            macData.labels.push(timestamp);\n            macData.temp.push(temp);\n            macData.hum.push(hum);\n            macData.lat.push(lat);\n\n            updateChartData(chartTempInstance, mac, macData.labels, macData.temp);\n            updateChartData(chartHumInstance, mac, macData.labels, macData.hum);\n            updateChartData(chartLatInstance, mac, macData.labels, macData.lat);\n        });\n\n        // --- Limpeza quando o template é removido/reimplantado ---\n        scope.$on('$destroy', function() {\n            console.log(\"[Node-RED UI] '$destroy' event fired. Destroying charts.\");\n            if (chartTempInstance) chartTempInstance.destroy();\n            if (chartHumInstance) chartHumInstance.destroy();\n            if (chartLatInstance) chartLatInstance.destroy();\n        });\n\n    })(scope);\n</script>",
