        "name": "parse_sucess_or_loss",
        "func": "const topic = msg.topic;\nconst payload = msg.payload;\n\n// Garante que é número mesmo\nif (topic.endsWith(\"/success_rate\")) {\n    flow.set(\"success_rate\", Number(payload));\n} else if (topic.endsWith(\"/packet_loss\")) {\n    flow.set(\"packet_loss\", Number(payload));\n}\n\n// Verifica se já tem os dois\nconst success = flow.get(\"success_rate\");\nconst loss = flow.get(\"packet_loss\");\n\n// Só envia quando tiver ambos e forem válidos\nif (\n    success !== undefined &&\n    loss !== undefined &&\n    !isNaN(success) &&\n    !isNaN(loss)\n) {\n    // Cria um objeto payload para o nó SQL\n    msg.payload = {\n        success_rate: success,\n        packet_loss: loss\n    };\n\n    // Limpa depois de usar\n    flow.set(\"success_rate\", undefined);\n    flow.set(\"packet_loss\", undefined);\n\n    return msg; \n}\n\nreturn null; // Espera o outro valor chegar",
