    {
        "id": "832fb7bd208b5c25",
        "type": "function",
        "z": "fe162edfc74f05cc",
        "name": "parse_rssi_or_hops",
        "func": "const topic = msg.topic;\nconst payload = msg.payload;\nlet mac, rssi, hops;\n\nif (topic.endsWith(\"/rssi\")) {\n    const parts = payload.split(\" - RSSI: \");\n    mac = parts[0].trim();\n    rssi = parseInt(parts[1].trim(), 10);\n\n    // Salva temporariamente\n    flow.set(mac + \"_rssi\", rssi);\n\n} else if (topic.endsWith(\"/hops\")) {\n    const parts = payload.split(\" - Hops: \");\n    mac = parts[0].trim();\n    hops = parseInt(parts[1].trim(), 10);\n\n    // Salva temporariamente\n    flow.set(mac + \"_hops\", hops);\n}\n\n// Verifica se os dois dados já chegaram\nconst savedRssi = flow.get(mac + \"_rssi\");\nconst savedHops = flow.get(mac + \"_hops\");\n\nif (savedRssi !== undefined && savedHops !== undefined) {\n    msg.mac_address = mac;\n    msg.rssi = savedRssi;\n    msg.hops = savedHops;\n\n    // Limpa os dados temporários\n    flow.set(mac + \"_rssi\", undefined);\n    flow.set(mac + \"_hops\", undefined);\n\n    return msg; // envia msg somente quando ambos estiverem presentes\n}\n\nreturn null; // ainda não recebeu ambos, então descarta por agora\n",
